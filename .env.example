# =============================================================================
# Estrevia — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# App URL (used for OG images, Stripe redirects, sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://estrevia.app

# Database (Neon)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Payments (Stripe) — not needed for bootstrap
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# A/B test coupons — create in Stripe Dashboard (20% off, duration=once)
# Required for paywall_teaser Variant C. Leave empty to degrade to Variant B behavior.
STRIPE_COUPON_TEASER20=


# PII Encryption — generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — not needed for bootstrap
RESEND_API_KEY=

# Analytics (PostHog) — not needed for bootstrap
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog server-side query API (advertising agent funnel reads)
# POSTHOG_PROJECT_ID  — numeric project id (PostHog UI → Settings → Project)
# POSTHOG_PERSONAL_API_KEY — Personal API key (PostHog UI → Settings → Personal API keys)
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# AI Analysis (Anthropic Claude API — synastry + tarot interpretation)
ANTHROPIC_API_KEY=

# AI Image/Video Generation (Google AI Studio — avatars, ad creatives)
GEMINI_API_KEY=

# Web Push Notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# VAPID public key (exposed to client for push subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Vercel Cron secret (auto-set by Vercel, or generate with: openssl rand -hex 32)
CRON_SECRET=

# ─────────────────────────────────────────────────────────
# Advertising Agent (Meta Ads autonomous management)
# ─────────────────────────────────────────────────────────
# Meta Marketing API (System User long-lived token from Business Manager)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_BUSINESS_ID=
META_PIXEL_ID=
META_CAPI_TOKEN=

# Meta Pixel — public id used by browser fbq() snippet. Mirror of META_PIXEL_ID
# (must match exactly). When unset, the Pixel base script in
# src/app/[locale]/layout.tsx is omitted (graceful no-op in dev / staging).
NEXT_PUBLIC_META_PIXEL_ID=

# CAPI optional test-events code — when set, all server-side CAPI events
# route to Meta's Test Events page instead of production attribution.
# MUST be UNSET (or empty) in production.
META_CAPI_TEST_EVENT_CODE=

# Facebook Page that owns the ads — required by Meta for every AdCreative.
# Find via: GET /<META_BUSINESS_ID>/owned_pages
META_PAGE_ID=1087394517790815

# Pre-created launch ad-sets (created by scripts/advertising/setup-meta-campaign.ts).
# Each locale gets its own ad-set so the 70/30 EN/ES budget split holds via ABO.
META_LAUNCH_ADSET_ID_EN=
META_LAUNCH_ADSET_ID_ES=

# Optional creative-gen fallbacks (only if Imagen/Veo defaults underperform)
IDEOGRAM_API_KEY=
RUNWAY_API_KEY=

# Telegram bot for daily digest, alerts, and high-priority approvals
TELEGRAM_BOT_TOKEN=
TELEGRAM_FOUNDER_CHAT_ID=

# Hard caps and master switches
ADVERTISING_DAILY_SPEND_CAP_USD=80
ADVERTISING_AGENT_ENABLED=false
ADVERTISING_AGENT_DRY_RUN=true

# Bearer token for Cowork to read /api/admin/advertising/status + /digest.
# Generate via: openssl rand -hex 32
# Add to Vercel `production` env. Rotate quarterly.
ADVERTISING_STATUS_BEARER=

# When true, retro-weekly cron audits top-10 creatives via ClaudeBrandVoiceClient
# and persists scores in advertising_brand_voice_scores. Default false during
# rollout — flip when the migration has been applied and you want to enable
# the audit. Disabled = no Claude API calls, no DB writes, /status returns
# { status: 'no_data', reason: 'Scorer disabled...' }.
BRAND_VOICE_SCORER_ENABLED=false

# When true, tier-2 alerts (sendAlert(..., { tier: 2 })) are suppressed
# from Telegram and surfaced only via the daily Cowork digest. Default
# false preserves pre-Patch-04 behavior. Flip after Cowork digest verified.
ADVERTISING_TIER2_VIA_DIGEST=false

# Marketing-psychology archetypes — peer_discovery requires verifiable
# social-proof backing. Flip to "true" only after PostHog chart_calculated
# events reach ≥2000 in production (manual check via PostHog UI).
# Default off — peer_discovery hooks are filtered out of creative-gen pipeline.
PEER_DISCOVERY_ENABLED=false

# ─────────────────────────────────────────────────────────
# Email retention
# ─────────────────────────────────────────────────────────
# HMAC secret for signed unsubscribe tokens (≥32 chars, generate: openssl rand -hex 32)
EMAIL_UNSUBSCRIBE_SECRET=
# Resend webhook signature secret (from Resend dashboard → Webhooks → Signing secret)
RESEND_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# Admin UI — allowlist
# ─────────────────────────────────────────────────────────
# Comma-separated list of Clerk-verified email addresses that may access
# /admin/* pages. Anyone not in this list is redirected to /.
# Example: ADMIN_ALLOWED_EMAILS=founder@example.com,ops@example.com
ADMIN_ALLOWED_EMAILS=
