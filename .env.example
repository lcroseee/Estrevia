# =============================================================================
# Estrevia — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# App URL (used for OG images, Stripe redirects, sitemap)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://estrevia.app

# Database (Neon)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Payments (Stripe) — not needed for bootstrap
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=

# PII Encryption — generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — not needed for bootstrap
RESEND_API_KEY=

# Analytics (PostHog) — not needed for bootstrap
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# AI Analysis (Anthropic Claude API — synastry + tarot interpretation)
ANTHROPIC_API_KEY=

# AI Image/Video Generation (Google AI Studio — avatars, ad creatives)
GEMINI_API_KEY=

# Web Push Notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# VAPID public key (exposed to client for push subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Vercel Cron secret (auto-set by Vercel, or generate with: openssl rand -hex 32)
CRON_SECRET=

# Meta Ads (post-MVP)
META_MARKETING_API_TOKEN=
META_APP_ID=
META_AD_ACCOUNT_ID=
