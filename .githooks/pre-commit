#!/bin/sh
# Pre-commit hook: block secrets and PII from being committed

# Check for .env files being staged (except .env.example)
if git diff --cached --name-only | grep -qE '^\.(env|env\.local|env\..*\.local)$'; then
  echo "ERROR: Attempting to commit .env file with secrets."
  echo "Remove it from staging: git reset HEAD .env"
  exit 1
fi

# Check for files that likely contain secrets
if git diff --cached --name-only | grep -qiE '\.(pem|key|cert|p12)$|credentials\.json|serviceAccountKey'; then
  echo "ERROR: Attempting to commit a file that may contain secrets."
  exit 1
fi

# Scan staged content for actual secret values (not empty variable names)
# Matches: sk_live_xxx, sk_test_xxx, pk_live_xxx, pk_test_xxx, whsec_xxx, private keys
SECRET_VALUES='(sk_live_[a-zA-Z0-9]+|sk_test_[a-zA-Z0-9]+|pk_live_[a-zA-Z0-9]+|pk_test_[a-zA-Z0-9]+|whsec_[a-zA-Z0-9]+|-----BEGIN (RSA |EC )?PRIVATE KEY)'

if git diff --cached -U0 --diff-filter=d \
     -- ':(exclude).githooks/*' ':(exclude).env.ci' \
   | grep -qE "$SECRET_VALUES"; then
  echo "ERROR: Staged changes contain what looks like a hardcoded secret."
  echo "Use process.env instead. Review with: git diff --cached"
  exit 1
fi

exit 0
